# Nepal Election OSINT Dashboard - Environment Variables
# Copy this file to .env.local and fill in the values

# Application
NEXT_PUBLIC_APP_NAME=Nepal Election OSINT Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox (Optional - for enhanced map visualization)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# API Configuration
API_RATE_LIMIT_WINDOW=60000
API_MAX_REQUESTS=30
API_CACHE_DURATION=20000

# RSS Feed Configuration
RSS_CACHE_DURATION=60000
RSS_MAX_ITEMS=20

# Election Data Source
ELECTION_DATA_URL=https://election.ratopati.com

# Monitoring Keywords
ELECTION_KEYWORDS=निर्वाचन,मतगणना,election,vote,candidate,उम्मेदवार,परिणाम

# Alert Thresholds
VOTE_MARGIN_THRESHOLD=1000
SEAT_PROJECTION_THRESHOLD=5
